{
  "name": "crew",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "build": {
    "appId": "app.crew",
    "productName": "crew",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite dev",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "dist": "electron-vite build && electron-builder",
    "postinstall": "node scripts/ensure-electron.mjs"
  },
  "dependencies": {
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@heroicons/react": "^2.2.0",
    "@mantine/core": "^8.3.11",
    "@mantine/hooks": "^8.3.11",
    "@tldraw/assets": "^5.2.5",
    "dompurify": "^3.1.6",
    "lucide-static": "^1.26.0",
    "marked": "^12.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shiki": "^4.3.1",
    "tldraw": "^5.2.5",
    "ws": "^8.18.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
